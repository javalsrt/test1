<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:paddingTop="60dp"
    android:paddingHorizontal="24dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <TextView android:id="@+id/tv_quiz_tag" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="⚡ 判断题"
            android:textSize="13sp" android:textColor="#FF9500"
            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
            android:background="@drawable/bg_tag" />
        <TextView android:id="@+id/tv_quiz_num" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="1/30"
            android:textSize="13sp" android:textColor="#86868B"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <TextView android:id="@+id/tv_quiz_question" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="题目内容"
        android:textSize="17sp" android:textColor="#1D1D1F"
        android:lineSpacingExtra="4dp" android:layout_marginBottom="32dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center" android:weightSum="2">

        <TextView android:id="@+id/btn_true" android:layout_width="0dp"
            android:layout_height="80dp" android:layout_weight="1"
            android:text="✅  正确" android:textSize="20sp" android:textColor="#34C759"
            android:gravity="center" android:background="@drawable/bg_card_entry"
            android:layout_marginEnd="12dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_false" android:layout_width="0dp"
            android:layout_height="80dp" android:layout_weight="1"
            android:text="❌  错误" android:textSize="20sp" android:textColor="#FF2D55"
            android:gravity="center" android:background="@drawable/bg_card_entry"
            android:layout_marginStart="12dp"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
</LinearLayout>
