<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- 用户信息头 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="40dp"
            android:paddingBottom="28dp"
            android:background="@color/white">

            <TextView
                android:id="@+id/tv_avatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="张"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/tv_real_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="张明"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_student_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="学号: 20240101001"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- 学习统计卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-20dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_hours" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="128"
                        android:textSize="24sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="学习时长(h)"
                        android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="0.5dp" android:layout_height="36dp"
                    android:background="@color/divider" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_quiz" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="342"
                        android:textSize="24sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="完成题目"
                        android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="0.5dp" android:layout_height="36dp"
                    android:background="@color/divider" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_rate" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="85.6%"
                        android:textSize="24sp" android:textColor="@color/accent_blue"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="正确率"
                        android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 功能列表 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:paddingHorizontal="16dp" android:gravity="center_vertical"
                    android:foreground="?android:attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="我的课程"
                        android:textSize="15sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="6门" android:textSize="13sp"
                        android:textColor="@color/text_tertiary" android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" />

                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:paddingHorizontal="16dp" android:gravity="center_vertical"
                    android:foreground="?android:attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="我的收藏"
                        android:textSize="15sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="12篇" android:textSize="13sp"
                        android:textColor="@color/text_tertiary" android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" />

                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:paddingHorizontal="16dp" android:gravity="center_vertical"
                    android:foreground="?android:attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="学习报告"
                        android:textSize="15sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="周报" android:textSize="13sp"
                        android:textColor="@color/text_tertiary" android:fontFamily="sans-serif" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 设置 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingVertical="4dp">

                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:paddingHorizontal="16dp" android:gravity="center_vertical"
                    android:foreground="?android:attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="设置"
                        android:textSize="15sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" />

                <LinearLayout
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:paddingHorizontal="16dp" android:gravity="center_vertical"
                    android:foreground="?android:attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="退出登录" android:textSize="15sp"
                        android:textColor="#FF3B30" android:fontFamily="sans-serif" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
