<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- 用户信息头 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="40dp"
                android:paddingBottom="28dp">

            <TextView
                android:id="@+id/tv_avatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="张"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/tv_real_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="张明"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_student_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="学号: 20240101001"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- 退出按钮（右上角） -->
            <TextView
                android:id="@+id/btn_logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="16dp"
                android:text="退出"
                android:textSize="14sp"
                android:textColor="#FF2D55"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true" />
        </FrameLayout>

        <!-- 学习统计卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-20dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_hours" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="128"
                        android:textSize="24sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="学习时长(分钟)"
                        android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="0.5dp" android:layout_height="36dp"
                    android:background="@color/divider" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_quiz" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="342"
                        android:textSize="24sp" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="完成题目"
                        android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="0.5dp" android:layout_height="36dp"
                    android:background="@color/divider" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_rate" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="85.6%"
                        android:textSize="24sp" android:textColor="@color/accent_blue"
                        android:fontFamily="sans-serif" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="正确率"
                        android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 收藏题目入口 -->
        <LinearLayout
            android:id="@+id/ll_bookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_entry"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📌 收藏题目"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_bookmark_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:textColor="@color/accent_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  >"
                android:textSize="14sp"
                android:textColor="#C7C7CC" />
        </LinearLayout>

        <!-- 我的课程（白色卡片） -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的课程"
                    android:textSize="15sp"
                    android:textColor="#86868B"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_courses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
