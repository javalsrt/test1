<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <TextView android:id="@+id/btn_back"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="‹" android:textSize="28sp" android:textColor="@color/primary"
            android:padding="8dp" android:clickable="true" android:focusable="true" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center">
            <TextView android:id="@+id/tv_title"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="专注刷题" android:textSize="17sp" android:textColor="@color/ink"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:paddingHorizontal="12dp" android:paddingVertical="4dp"
            android:background="@drawable/bg_tag">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⏱ " android:textSize="16sp" />
            <TextView android:id="@+id/tv_timer_corner"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="00:00" android:textSize="16sp" android:textColor="@color/primary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/ll_info"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:paddingStart="52dp" android:paddingEnd="16dp" android:paddingBottom="10dp">
        <TextView android:id="@+id/tv_today" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="今日专注 0 分钟"
            android:textSize="12sp" android:textColor="@color/ink_subtle" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" · " android:textSize="12sp" android:textColor="@color/ink_tertiary" />
        <TextView android:id="@+id/tv_last" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="上次 0 分钟"
            android:textSize="12sp" android:textColor="@color/ink_subtle" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/hairline" />

    <!-- 切换容器 -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">

        <!-- 8面板网格 -->
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
            android:fillViewport="true">
        <LinearLayout android:id="@+id/ll_panels"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp" android:paddingTop="16dp" android:paddingBottom="24dp">

            <!-- 第1行 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <FrameLayout android:id="@+id/quiz_panel_1" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/quiz_panel_2" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
            </LinearLayout>
            <!-- 第2行 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <FrameLayout android:id="@+id/quiz_panel_3" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/quiz_panel_4" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
            </LinearLayout>
            <!-- 第3行 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <FrameLayout android:id="@+id/quiz_panel_5" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/quiz_panel_6" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
            </LinearLayout>
            <!-- 第4行 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" android:orientation="horizontal">
                <FrameLayout android:id="@+id/quiz_panel_7" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/quiz_panel_8" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:background="@drawable/bg_card_entry" android:clickable="true" android:focusable="true" />
            </LinearLayout>
        </LinearLayout>
        </ScrollView>

        <!-- 答题区 -->
        <LinearLayout android:id="@+id/ll_quiz_area"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:visibility="gone"
            android:background="@color/canvas">
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewpager_quiz"
                android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:padding="16dp" android:background="@color/canvas">
                <TextView android:id="@+id/btn_quiz_done"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:text="长按提交" android:textSize="14sp" android:textColor="@color/on_primary"
                    android:gravity="center" android:background="@drawable/bg_btn_primary"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true" android:focusable="true" android:longClickable="true" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
