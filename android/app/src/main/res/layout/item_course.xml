<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="14dp"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- 课程图标 -->
    <TextView
        android:id="@+id/tv_course_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="📖"
        android:textSize="22sp"
        android:background="@drawable/bg_circle_light" />

    <!-- 课程信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/tv_course_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="课程名"
            android:textSize="15sp"
            android:textColor="#1D1D1F"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_course_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="教室 · 教师"
            android:textSize="12sp"
            android:textColor="#86868B"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- 红点（未读消息） -->
    <TextView
        android:id="@+id/tv_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="18dp"
        android:gravity="center"
        android:text="1"
        android:textSize="10sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_badge_red"
        android:paddingHorizontal="4dp"
        android:layout_marginEnd="4dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <!-- 状态标签 -->
    <TextView
        android:id="@+id/tv_course_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="已下架"
        android:textSize="10sp"
        android:textColor="#FF9500"
        android:background="#FFF8F0"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:layout_marginEnd="8dp"
        android:visibility="gone" />

    <!-- 箭头 -->
    <TextView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:text="›"
        android:textSize="20sp"
        android:textColor="#C7C7CC"
        android:gravity="center" />
</LinearLayout>
